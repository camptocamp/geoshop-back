msgid "accessibility"
msgstr "Zugangsstufe"

msgid ""
"<li><b>Public</b>: data can be downloaded without restrictions.</li>\n"
"<li><b>Approval needed</b>: The contact of this metadata with <i>is "
"validator?</i> set\n"
"  to true will have to validate this product for extraction</li>\n"
"<li><b>Not accessible</b>: The metadata is public, everybody knows the data "
"exists but it's\n"
"  not possible to order it (unless you explicitly create a product).</li>\n"
"<li><b>Internal</b>: The metadata is not published.</li>"
msgstr ""
"<li><b>Öffentlich</b>: Daten können ohne Einschränkungen heruntergeladen "
"werden.</li>\n"
"<li><b>Eingeschränkte Verbreitung</b>: Der Kontakt dieser Metadaten, bei dem "
"<i>ist Validator?</i> aktiviert ist, muss die Bestellung vor der "
"Übermittlung an Extract validieren</li>\n"
"<li><b>Nicht verbreitet, öffentliche Metadaten</b>: Die Metadaten sind "
"öffentlich, aber nicht die Geodaten (es sei denn, ein Produkt wird eigens im "
"Geoshop erstellt).</li>\n"
"<li><b>Nicht verbreitet, interne Metadaten</b>: Die Metadaten sind für die "
"Öffentlichkeit nicht sichtbar.</li>"

